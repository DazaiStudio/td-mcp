# Force LF line endings on text files (prevents CRLF vs LF churn on
# Windows contributors — Biome's formatter assumes LF).
* text=auto eol=lf

# Binary files — don't touch.
*.tox      binary
*.mcpb     binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.mp4      binary
*.pdf      binary
*.zip      binary
*.ico      binary

# Generated files — don't count against diffs in GitHub UI.
src/gen/**              linguist-generated=true
td/modules/td_server/** linguist-generated=true
package-lock.json       linguist-generated=true
